<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.1.dtd" >
<suite name="flight-reservation-test">

    <test name="passengers-count-1">
        <parameter name="numOfPassengers" value="1" />
        <parameter name="expectedPrice" value="$584 USD" />
        <classes>
            <class name="com.nal.tests.flightreservation.FlightReservationTest"/>
        </classes>
    </test>
    <test name="passengers-count-2">
        <parameter name="numOfPassengers" value="2" />
        <parameter name="expectedPrice" value="$1169 USD" />
        <classes>
            <class name="com.nal.tests.flightreservation.FlightReservationTest"/>
        </classes>
    </test>
    <test name="passengers-count-3">
        <parameter name="numOfPassengers" value="3" />
        <parameter name="expectedPrice" value="$1753 USD" />
        <classes>
            <class name="com.nal.tests.flightreservation.FlightReservationTest"/>
        </classes>
    </test>
    <test name="passengers-count-4">
        <parameter name="numOfPassengers" value="4" />
        <parameter name="expectedPrice" value="$2338 USD" />
        <classes>
            <class name="com.nal.tests.flightreservation.FlightReservationTest"/>
        </classes>
    </test>

</suite>